{
  "_comment": [
    "Spike workflow: img2img with ControlNet OpenPose, no inpaint mask.",
    "Probes whether init=cached-gen + ControlNet=new-pose can adapt pose at",
    "moderate denoise without losing identity. Pairs with scripts/experiments/spike_img2img_pose.py.",
    "",
    "Uses the non-inpaint checkpoint variant — VAEEncode produces standard",
    "4-channel latents, and the inpaint variant expects 9-channel input (mask",
    "channels), so img2img must use the plain checkpoint.",
    "",
    "Required ComfyUI models:",
    "  checkpoints/Realistic_Vision_V6.0_NV_B1_fp16.safetensors",
    "  vae/vae-ft-mse-840000-ema-pruned.safetensors",
    "  controlnet/control_v11p_sd15_openpose.pth"
  ],
  "_node_ids": {
    "positive":    "3",
    "negative":    "4",
    "load_image":  "5",
    "load_pose":   "13",
    "controlnet":  "14",
    "vae_encode":  "16",
    "ksampler":    "9",
    "save_image":  "11"
  },
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "Realistic_Vision_V6.0_NV_B1_fp16.safetensors"
    }
  },
  "15": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "vae-ft-mse-840000-ema-pruned.safetensors"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "a person, neutral appearance, warm skin tone, soft natural light",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "deformed, artifacts, blurry, extra limbs, low quality, blue skin, grey skin, washed out",
      "clip": ["1", 1]
    }
  },
  "5": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "init_placeholder.png"
    }
  },
  "16": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["5", 0],
      "vae":    ["15", 0]
    }
  },
  "12": {
    "class_type": "ControlNetLoader",
    "inputs": {
      "control_net_name": "control_v11p_sd15_openpose.pth"
    }
  },
  "13": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "pose_placeholder.png"
    }
  },
  "14": {
    "class_type": "ControlNetApplyAdvanced",
    "inputs": {
      "positive":      ["3", 0],
      "negative":      ["4", 0],
      "control_net":   ["12", 0],
      "image":         ["13", 0],
      "strength":      1.0,
      "start_percent": 0.0,
      "end_percent":   1.0
    }
  },
  "9": {
    "class_type": "KSampler",
    "inputs": {
      "model":        ["1", 0],
      "positive":     ["14", 0],
      "negative":     ["14", 1],
      "latent_image": ["16", 0],
      "seed":         42,
      "steps":        20,
      "cfg":          3.5,
      "sampler_name": "dpmpp_2m",
      "scheduler":    "karras",
      "denoise":      0.5
    }
  },
  "10": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["9", 0],
      "vae":     ["15", 0]
    }
  },
  "11": {
    "class_type": "SaveImage",
    "inputs": {
      "images":          ["10", 0],
      "filename_prefix": "spike_img2img_pose"
    }
  }
}
